DATABASE_URL=postgresql://oppsera_app:oppsera_dev@localhost:5432/oppsera_dev
DATABASE_URL_ADMIN=postgresql://oppsera:oppsera_dev@localhost:5432/oppsera_dev
REDIS_URL=redis://localhost:6379
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_JWT_JWK={"x":"...","y":"...","alg":"ES256","crv":"P-256","kty":"EC","key_ops":["verify"]}
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3002
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NODE_ENV=development
DEV_AUTH_BYPASS=true  # Set to 'true' to bypass Supabase auth and login with any seeded user (dev only)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here  # Required for AI Insights chat (/insights)
ADMIN_AUTH_SECRET=your-admin-secret-at-least-32-characters  # Required for admin panel JWT signing
CRON_SECRET=your-cron-secret-here  # Required for internal cron endpoints (drain-outbox, cleanup-tabs, send-reminders)
SENTRY_DSN=  # Optional: Sentry error tracking DSN
SENTRY_ORG=  # Optional: Sentry organization slug (for source maps upload)
SENTRY_PROJECT=  # Optional: Sentry project slug
SENTRY_AUTH_TOKEN=  # Optional: Sentry auth token (for source maps upload)
BOT_ALLOWLIST_IPS=  # Optional: comma-separated IPs to exclude from bot detection
