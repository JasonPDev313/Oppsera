{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --filter @oppsera/admin...",
  "buildCommand": "cd ../.. && NODE_OPTIONS=--max-old-space-size=16384 pnpm run build --filter @oppsera/admin",
  "crons": [
    {
      "path": "/api/v1/admin/backups/cron",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/v1/analytics/attrition/cron",
      "schedule": "0 2 * * *"
    }
  ]
}
